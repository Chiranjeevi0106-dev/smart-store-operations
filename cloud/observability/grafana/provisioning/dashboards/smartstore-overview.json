{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Stockout Rate by Store",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "TimescaleDB",
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, store_id, stockout_rate_pct AS value FROM hourly_stockout_rate WHERE $__timeFilter(bucket) ORDER BY bucket",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5.3 },
              { "color": "red", "value": 8 }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Avg Queue Wait by Store",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "TimescaleDB",
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, store_id, avg_wait_seconds AS value FROM hourly_queue_stats WHERE $__timeFilter(bucket) ORDER BY bucket",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 294 },
              { "color": "red", "value": 408 }
            ]
          }
        }
      }
    },
    {
      "title": "Edge Node Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "avg(up{job='edge-nodes'}) * 100" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Inference Latency (p95)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(inference_duration_seconds_bucket{job='inference-servers'}[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 150,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "LP Alerts / Day",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": "TimescaleDB",
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, store_id, total_alerts AS value FROM daily_lp_summary WHERE $__timeFilter(bucket) ORDER BY bucket",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum by (topic) (kafka_consumer_group_lag{group='fusion-consumer'})" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["smartstore", "operations"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "Smart Store Operations — Overview",
  "uid": "smartstore-overview"
}
